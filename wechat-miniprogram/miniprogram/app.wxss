page {
  min-height: 100%;
  background: #09111f;
  color: #f7f9fc;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

view,
text,
input,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  line-height: normal;
}

button::after {
  border: 0;
}
